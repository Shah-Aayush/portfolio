---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = (d) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title="Writing — Aayush Shah" description="Notes on systems, infrastructure, and learning machine learning in public.">
  <section>
    <div class="eyebrow">Writing</div>
    <h1 style="font-size: clamp(2rem, 5vw, 2.6rem); margin-bottom: 8px;">Notes &amp; writeups</h1>
    <p style="color: var(--text-soft); margin-bottom: 28px; max-width: 52ch;">
      Thinking out loud about systems, infrastructure, and learning machine learning in public.
    </p>

    {posts.length === 0 ? (
      <p style="color: var(--text-faint);">No posts yet — first one coming soon.</p>
    ) : (
      posts.map((post) => (
        <a class="post-link" href={`/blog/${post.id}/`}>
          <span class="date">{fmt(post.data.date)}</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))
    )}
  </section>
</Base>
