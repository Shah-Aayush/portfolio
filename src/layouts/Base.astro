---
import '../styles/global.css';

const { title = 'Aayush Shah — Software Engineer', description = 'Software engineer building reliable systems, infrastructure, and developer tooling.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="nav">
      <div class="wrap">
        <a href="/" class="brand">Aayush Shah</a>
        <div class="links">
          <a href="/#work">Work</a>
          <a href="/#projects">Projects</a>
          <a href="/blog">Writing</a>
          <a href="/#contact">Contact</a>
        </div>
      </div>
    </nav>

    <main class="wrap">
      <slot />
    </main>

    <footer>
      <div class="wrap">
        © {new Date().getFullYear()} Aayush Shah · Built with Astro
      </div>
    </footer>
  </body>
</html>
